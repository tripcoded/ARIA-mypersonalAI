# Groq API key for chat responses
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=""

# Groq chat model
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Base directory for writable app data (uploads + vector store)
# Example on Render: /opt/render/project/src/backend/storage
DATA_DIR=.

# Chroma vector database directory
CHROMA_DB_DIR=./chroma_db

# Upload directory
UPLOAD_DIR=./uploads

# Optional comma-separated list of extra frontend origins for CORS
CORS_ALLOWED_ORIGINS=

# GitHub token
# Optional for public repositories, recommended for private repositories and higher rate limits.
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=""

# GitHub ingestion limits
# Reduce these values if large repositories take too long to index.
GITHUB_MAX_FILES=150
GITHUB_MAX_FILE_BYTES=200000
